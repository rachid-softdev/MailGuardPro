{
  "name": "@mailguardpro/root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter mailguardpro-web dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter mailguardpro-web build",
    "start": "pnpm --filter mailguardpro-web start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "pnpm run format:check \u0026\u0026 pnpm run lint \u0026\u0026 pnpm run typecheck",
    "prepare": "husky",
    "test": "turbo run test",
    "web:dev": "pnpm --filter mailguardpro-web dev",
    "web:build": "pnpm --filter mailguardpro-web build",
    "web:start": "pnpm --filter mailguardpro-web start",
    "web:lint": "pnpm --filter mailguardpro-web lint",
    "web:typecheck": "pnpm --filter mailguardpro-web typecheck",
    "check-env": "pnpm --filter mailguardpro-web check-env",
    "db:generate": "pnpm --filter @mailguardpro/web db:generate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset tag",
    "ci:release": "pnpm changeset version \u0026\u0026 pnpm install --no-frozen-lockfile \u0026\u0026 pnpm build \u0026\u0026 pnpm changeset tag"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "@changesets/cli": "^2.27.0",
    "@changesets/changelog-github": "^0.5.0"
  },
  "lint-staged": {
    "*": [
      "biome format --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "pnpm": {
    "overrides": {
      "@prisma/client": "^7.8.0"
    }
  }
}
