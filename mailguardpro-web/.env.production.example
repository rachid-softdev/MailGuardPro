# Production Environment Override
# Copy to .env.production.local and customize for production

# Database
# DATABASE_URL=postgresql://user:password@prod-host:5432/database

# Redis
# REDIS_URL=redis://prod-host:6379

# NextAuth.js v5
# AUTH_SECRET=your-production-secret-min-32-chars

# Google OAuth
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend
# AUTH_RESEND_KEY=re_xxxxxxxxxxxx
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe (use live keys!)
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_xxxxx