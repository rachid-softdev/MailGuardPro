import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'
import { WebhookDispatcher, WEBHOOK_EVENTS, createBulkJobCompletedPayload, WebhookConfig } from '@/services/webhookDispatcher'

// Mock crypto
const mockHMAC = {
  update: vi.fn().mockReturnThis(),
  digest: vi.fn().mockReturnValue(Buffer.from('abc123')),
}

vi.mock('crypto', () => ({
  createHmac: vi.fn(() => mockHMAC),
  timingSafeEqual: vi.fn((a: Buffer, b: Buffer) => true),
}))

// Mock fetch
global.fetch = vi.fn()

describe('webhookDispatcher', () => {
  const mockWebhook: WebhookConfig = {
    id: 'webhook-123',
    url: 'https://example.com/webhook',
    secret: 'secret-key',
    events: ['bulk_job_completed'],
    isActive: true,
  }

  beforeEach(() => {
    vi.clearAllMocks()
    vi.mocked(fetch).mockReset()
  })

  afterEach(() => {
    vi.restoreAllMocks()
  })

  describe('dispatch', () => {
    it('should return false when webhook is inactive', async () => {
      const inactiveWebhook = { ...mockWebhook, isActive: false }

      const result = await WebhookDispatcher.dispatch(inactiveWebhook, 'bulk_job_completed', {})

      expect(result).toBe(false)
      expect(fetch).not.toHaveBeenCalled()
    })

    it('should return false when event is not in webhook events', async () => {
      const result = await WebhookDispatcher.dispatch(mockWebhook, 'other_event', {})

      expect(result).toBe(false)
      expect(fetch).not.toHaveBeenCalled()
    })

    it('should return true on successful dispatch', async () => {
      vi.mocked(fetch).mockResolvedValue({
        ok: true,
        status: 200,
        statusText: 'OK',
      } as any)

      const result = await WebhookDispatcher.dispatch(mockWebhook, 'bulk_job_completed', {
        jobId: 'job-123',
      })

      expect(result).toBe(true)
      expect(fetch).toHaveBeenCalledWith(
        'https://example.com/webhook',
        expect.objectContaining({
          method: 'POST',
          headers: expect.objectContaining({
            'Content-Type': 'application/json',
            'X-MailGuard-Event': 'bulk_job_completed',
          }),
        })
      )
    })

    it('should include signature in headers', async () => {
      vi.mocked(fetch).mockResolvedValue({
        ok: true,
        status: 200,
        statusText: 'OK',
      } as any)

      await WebhookDispatcher.dispatch(mockWebhook, 'bulk_job_completed', {})

      expect(fetch).toHaveBeenCalledWith(
        expect.any(String),
        expect.objectContaining({
          headers: expect.objectContaining({
            'X-MailGuard-Signature': expect.any(String),
          }),
        })
      )
    })

    it('should retry on failure', async () => {
      vi.mocked(fetch)
        .mockRejectedValueOnce(new Error('Network error'))
        .mockRejectedValueOnce(new Error('Network error'))
        .mockResolvedValueOnce({
          ok: true,
          status: 200,
          statusText: 'OK',
        } as any)

      const result = await WebhookDispatcher.dispatch(mockWebhook, 'bulk_job_completed', {})

      expect(result).toBe(true)
      expect(fetch).toHaveBeenCalledTimes(3)
    })

    it('should return false after all retries fail', async () => {
      vi.mocked(fetch).mockRejectedValue(new Error('Network error'))

      const result = await WebhookDispatcher.dispatch(mockWebhook, 'bulk_job_completed', {})

      expect(result).toBe(false)
      // Should have tried 3 times (MAX_RETRIES)
      expect(fetch).toHaveBeenCalledTimes(3)
    })

    it('should handle non-ok responses', async () => {
      vi.mocked(fetch).mockResolvedValue({
        ok: false,
        status: 500,
        statusText: 'Internal Server Error',
      } as any)

      const result = await WebhookDispatcher.dispatch(mockWebhook, 'bulk_job_completed', {})

      expect(result).toBe(false)
    })
  })

  describe('dispatchToUser', () => {
    it('should dispatch to all active webhooks for user', async () => {
      const { prisma } = await import('@/lib/prisma')
      vi.mocked(prisma.webhook.findMany).mockResolvedValue([
        { id: '1', url: 'https://webhook1.com', secret: 's1', events: ['bulk_job_completed'], isActive: true, userId: 'user-1' },
        { id: '2', url: 'https://webhook2.com', secret: 's2', events: ['bulk_job_completed'], isActive: true, userId: 'user-1' },
      ] as any)

      vi.mocked(fetch).mockResolvedValue({
        ok: true,
        status: 200,
        statusText: 'OK',
      } as any)

      const result = await WebhookDispatcher.dispatchToUser('user-1', 'bulk_job_completed', {})

      expect(result.total).toBe(2)
      expect(result.successful).toBe(2)
      expect(result.failed).toBe(0)
    })

    it('should skip inactive webhooks', async () => {
      const { prisma } = await import('@/lib/prisma')
      vi.mocked(prisma.webhook.findMany).mockResolvedValue([
        { id: '1', url: 'https://webhook1.com', secret: 's1', events: ['bulk_job_completed'], isActive: true, userId: 'user-1' },
        { id: '2', url: 'https://webhook2.com', secret: 's2', events: ['bulk_job_completed'], isActive: false, userId: 'user-1' },
      ] as any)

      vi.mocked(fetch).mockResolvedValue({
        ok: true,
        status: 200,
        statusText: 'OK',
      } as any)

      const result = await WebhookDispatcher.dispatchToUser('user-1', 'bulk_job_completed', {})

      expect(result.total).toBe(1)
    })

    it('should filter by event type', async () => {
      const { prisma } = await import('@/lib/prisma')
      vi.mocked(prisma.webhook.findMany).mockResolvedValue([
        { id: '1', url: 'https://webhook1.com', secret: 's1', events: ['other_event'], isActive: true, userId: 'user-1' },
      ] as any)

      const result = await WebhookDispatcher.dispatchToUser('user-1', 'bulk_job_completed', {})

      expect(result.total).toBe(0)
    })

    it('should return results when no webhooks found', async () => {
      const { prisma } = await import('@/lib/prisma')
      vi.mocked(prisma.webhook.findMany).mockResolvedValue([])

      const result = await WebhookDispatcher.dispatchToUser('user-1', 'bulk_job_completed', {})

      expect(result.total).toBe(0)
      expect(result.successful).toBe(0)
    })
  })

  describe('verifyIncomingSignature', () => {
    it('should return true for valid signature', () => {
      const payload = '{"event":"test"}'
      const signature = 'abc123'
      const secret = 'secret'

      const result = WebhookDispatcher.verifyIncomingSignature(payload, signature, secret)

      expect(result).toBe(true)
    })

    it('should return false for invalid signature', () => {
      vi.mocked(require('crypto').timingSafeEqual).mockReturnValueOnce(false)

      const result = WebhookDispatcher.verifyIncomingSignature('{}', 'invalid', 'secret')

      expect(result).toBe(false)
    })
  })

  describe('WEBHOOK_EVENTS', () => {
    it('should have correct event values', () => {
      expect(WEBHOOK_EVENTS.BULK_JOB_COMPLETED).toBe('bulk_job_completed')
      expect(WEBHOOK_EVENTS.BULK_JOB_FAILED).toBe('bulk_job_failed')
      expect(WEBHOOK_EVENTS.DAILY_REPORT).toBe('daily_report')
      expect(WEBHOOK_EVENTS.CREDIT_LOW).toBe('credit_low')
      expect(WEBHOOK_EVENTS.PLAN_UPGRADED).toBe('plan_upgraded')
      expect(WEBHOOK_EVENTS.PLAN_EXPIRED).toBe('plan_expired')
    })
  })

  describe('createBulkJobCompletedPayload', () => {
    it('should create payload with correct structure', () => {
      const payload = createBulkJobCompletedPayload('job-123', 100, {
        valid: 80,
        invalid: 10,
        risky: 10,
      })

      expect(payload.jobId).toBe('job-123')
      expect(payload.totalEmails).toBe(100)
      expect(payload.results.valid).toBe(80)
      expect(payload.results.invalid).toBe(10)
      expect(payload.results.risky).toBe(10)
      expect(payload.deliveredRate).toBe(80)
      expect(payload.timestamp).toBeDefined()
    })

    it('should calculate delivered rate correctly', () => {
      const payload = createBulkJobCompletedPayload('job-123', 50, {
        valid: 25,
        invalid: 15,
        risky: 10,
      })

      expect(payload.deliveredRate).toBe(50) // 25/50 = 50%
    })
  })
})