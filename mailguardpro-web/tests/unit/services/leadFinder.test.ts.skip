import { describe, it, expect, vi, beforeEach } from 'vitest'
import { findLeadEmail, findLeadEmails, LeadFinderInput } from '@/services/leadFinder'

// Mock emailValidator
vi.mock('@/services/emailValidator', () => ({
  validateEmail: vi.fn(),
}))

import { validateEmail } from '@/services/emailValidator'

describe('leadFinder', () => {
  beforeEach(() => {
    vi.clearAllMocks()
  })

  describe('findLeadEmail', () => {
    it('should return null when firstName is missing', async () => {
      const result = await findLeadEmail({
        lastName: 'Doe',
        companyDomain: 'example.com',
      })

      expect(result).toBeNull()
    })

    it('should return null when lastName is missing', async () => {
      const result = await findLeadEmail({
        firstName: 'John',
        companyDomain: 'example.com',
      })

      expect(result).toBeNull()
    })

    it('should return null when companyDomain is missing', async () => {
      const result = await findLeadEmail({
        firstName: 'John',
        lastName: 'Doe',
      })

      expect(result).toBeNull()
    })

    it('should return email without validation when validate is false', async () => {
      const result = await findLeadEmail(
        {
          firstName: 'John',
          lastName: 'Doe',
          companyDomain: 'example.com',
        },
        false
      )

      expect(result).not.toBeNull()
      expect(result!.email).toContain('@example.com')
      expect(result!.isValid).toBe(false)
      expect(result!.confidence).toBe(0.3)
    })

    it('should validate and return valid email', async () => {
      vi.mocked(validateEmail).mockResolvedValue({
        email: 'john.doe@example.com',
        score: 85,
        status: 'valid' as const,
        checks: {},
        domain: {},
        processingTimeMs: 100,
      })

      const result = await findLeadEmail({
        firstName: 'John',
        lastName: 'Doe',
        companyDomain: 'example.com',
      })

      expect(result).not.toBeNull()
      expect(result!.isValid).toBe(true)
      expect(result!.confidence).toBe(0.85)
    })

    it('should return lower confidence for risky emails', async () => {
      vi.mocked(validateEmail).mockResolvedValue({
        email: 'john.doe@example.com',
        score: 50,
        status: 'risky' as const,
        checks: {},
        domain: {},
        processingTimeMs: 100,
      })

      const result = await findLeadEmail({
        firstName: 'John',
        lastName: 'Doe',
        companyDomain: 'example.com',
      })

      expect(result!.confidence).toBe(0.35) // 0.5 * 0.7 = 0.35
    })

    it('should use known email to infer pattern', async () => {
      vi.mocked(validateEmail).mockResolvedValue({
        email: 'j.doe@example.com',
        score: 90,
        status: 'valid' as const,
        checks: {},
        domain: {},
        processingTimeMs: 100,
      })

      const result = await findLeadEmail({
        firstName: 'John',
        lastName: 'Doe',
        companyDomain: 'example.com',
        knownEmail: 'j.doe@example.com',
      })

      expect(result).not.toBeNull()
      // Should use inferred pattern {f}.{last}@{domain}
      expect(result!.pattern).toContain('f')
    })

    it('should continue to next pattern on validation error', async () => {
      vi.mocked(validateEmail)
        .mockRejectedValueOnce(new Error('Network error'))
        .mockResolvedValueOnce({
          email: 'john.doe@example.com',
          score: 85,
          status: 'valid' as const,
          checks: {},
          domain: {},
          processingTimeMs: 100,
        })

      const result = await findLeadEmail({
        firstName: 'John',
        lastName: 'Doe',
        companyDomain: 'example.com',
      })

      expect(result).not.toBeNull()
      expect(validateEmail).toHaveBeenCalledTimes(2)
    })

    it('should skip generic email patterns like contact@ and info@', async () => {
      // With validate=false, it returns first non-generic pattern
      const result = await findLeadEmail(
        {
          firstName: 'Contact',
          lastName: 'Person',
          companyDomain: 'example.com',
        },
        false
      )

      expect(result).not.toBeNull()
      expect(result!.email).not.toMatch(/^(contact|info)@/)
    })

    it('should return null when no patterns work', async () => {
      vi.mocked(validateEmail).mockResolvedValue({
        email: 'test@example.com',
        score: 20,
        status: 'invalid' as const,
        checks: {},
        domain: {},
        processingTimeMs: 100,
      })

      const result = await findLeadEmail({
        firstName: 'John',
        lastName: 'Doe',
        companyDomain: 'example.com',
      })

      // All patterns fail validation
      expect(result).toBeNull()
    })
  })

  describe('findLeadEmails', () => {
    it('should process multiple inputs and return results', async () => {
      vi.mocked(validateEmail).mockResolvedValue({
        email: 'john.doe@example.com',
        score: 85,
        status: 'valid' as const,
        checks: {},
        domain: {},
        processingTimeMs: 100,
      })

      const inputs: LeadFinderInput[] = [
        { firstName: 'John', lastName: 'Doe', companyDomain: 'example.com' },
        { firstName: 'Jane', lastName: 'Smith', companyDomain: 'test.com' },
      ]

      const results = await findLeadEmails(inputs)

      expect(results).toHaveLength(2)
    })

    it('should call onProgress callback', async () => {
      vi.mocked(validateEmail).mockResolvedValue({
        email: 'john.doe@example.com',
        score: 85,
        status: 'valid' as const,
        checks: {},
        domain: {},
        processingTimeMs: 100,
      })

      const onProgress = vi.fn()

      const inputs: LeadFinderInput[] = [
        { firstName: 'John', lastName: 'Doe', companyDomain: 'example.com' },
      ]

      await findLeadEmails(inputs, onProgress)

      expect(onProgress).toHaveBeenCalledWith(1, 1)
    })

    it('should handle partial failures gracefully', async () => {
      vi.mocked(validateEmail)
        .mockResolvedValueOnce({
          email: 'john.doe@example.com',
          score: 85,
          status: 'valid' as const,
          checks: {},
          domain: {},
          processingTimeMs: 100,
        })
        .mockResolvedValueOnce({
          email: 'jane.smith@test.com',
          score: 20,
          status: 'invalid' as const,
          checks: {},
          domain: {},
          processingTimeMs: 100,
        })

      const inputs: LeadFinderInput[] = [
        { firstName: 'John', lastName: 'Doe', companyDomain: 'example.com' },
        { firstName: 'Jane', lastName: 'Smith', companyDomain: 'test.com' },
      ]

      const results = await findLeadEmails(inputs)

      expect(results).toHaveLength(1)
      expect(results[0].email).toBe('john.doe@example.com')
    })

    it('should skip invalid inputs', async () => {
      const onProgress = vi.fn()

      const inputs: LeadFinderInput[] = [
        { firstName: 'John', lastName: 'Doe', companyDomain: 'example.com' },
        { firstName: '', lastName: 'Smith', companyDomain: 'test.com' }, // Invalid
      ]

      const results = await findLeadEmails(inputs, onProgress)

      expect(results).toHaveLength(1)
    })
  })
})