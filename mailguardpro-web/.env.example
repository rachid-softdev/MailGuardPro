# MailGuardPro Environment Variables
# Copy this file to .env.local and fill in the values

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis (rate limiting + BullMQ queue)
# Redis (required — generate with: openssl rand -hex 32)
REDIS_PASSWORD=
REDIS_URL=redis://host:6379

# NextAuth.js v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend (magic links + notifications)
AUTH_RESEND_KEY=re_xxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@mailguard.pro

# Security — HMAC keys (32+ chars each — generate with: openssl rand -hex 32)
# IP_HASH_KEY: HMAC-hashes IP addresses for privacy compliance (GDPR).
#              Required in production — fallback SHA-256 used in dev.
# Generate with: openssl rand -hex 32
IP_HASH_KEY=<your-64-char-hex-string>
# EMAIL_HASH_SALT: Salt for email hashing (used in anonymized validation).
#                  Required in production — insecure default used in dev.
#                  WARNING: Changing invalidates all existing email hashes.
# Generate with: openssl rand -hex 32
EMAIL_HASH_SALT=<your-64-char-hex-string>
# Generate with: openssl rand -hex 32
API_KEY_PEPPER=<your-64-char-hex-string>
# Generate with: openssl rand -hex 32
CRON_SECRET=<your-64-char-hex-string>

# Token encryption (32 bytes = 64 hex chars — generate with: openssl rand -hex 32)
# Required in production for OAuth token & webhook secret encryption
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=<your-64-char-hex-string>

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_monthly
STRIPE_DOWNGRADE_ATTEMPT_THRESHOLD=3

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node
NODE_ENV=development