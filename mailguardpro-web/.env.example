# MailGuardPro Environment Variables
# Copy this file to .env.local and fill in the values

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis (rate limiting + BullMQ queue)
REDIS_URL=redis://host:6379

# NextAuth.js v5
AUTH_SECRET=your-secret-key-min-32-characters-long
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend (magic links + notifications)
AUTH_RESEND_KEY=re_xxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@mailguard.pro

# Security
API_KEY_PEPPER=change-me-to-a-random-secret-min-32-chars
CRON_SECRET=change-me-to-a-random-secret

# Token encryption (32 bytes = 64 hex chars — generate with: openssl rand -hex 32)
# Required in production for OAuth token & webhook secret encryption
TOKEN_ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_monthly
STRIPE_DOWNGRADE_ATTEMPT_THRESHOLD=3

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node
NODE_ENV=development