{
  "name": "@mailguardpro/web",
  "version": "1.0.0",
  "description": "Email Intelligence Platform — Score quality 0-100 + bulk validation + exports",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
