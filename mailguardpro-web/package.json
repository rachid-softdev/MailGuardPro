{
  "name": "@mailguardpro/web",
  "version": "1.0.0",
  "description": "Email Intelligence Platform — Score quality 0-100 + bulk validation + exports",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "worker": "tsx worker/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky install"
  },
  "dependencies": {
    "@mailguardpro/types": "workspace:*",
    "@mailguardpro/utils": "workspace:*",
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.1.0",
    "@react-pdf/renderer": "^4.0.0",
    "bullmq": "^5.28.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.0.5",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "fast-levenshtein": "^3.0.0",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.469.0",
    "next": "15.1.0",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "resend": "^4.0.1",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.1.0",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/fast-levenshtein": "^0.0.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "@biomejs/biome": "^1.9.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
