generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  plan                 Plan      @default(FREE)
  credits              Int       @default(100)
  createdAt            DateTime  @default(now())
  role                 Role      @default(USER)
  isActive             Boolean   @default(true)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  tokenVersion         Int       @default(0) // Incremented on API key revocation
  organizationId       String?   @map("organization_id")

  accounts    Account[]
  sessions    Session[]
  apiKeys     ApiKey[]
  bulkJobs    BulkJob[]
  webhooks    Webhook[]
  validations       Validation[]
  userRoles         UserRole[]
  deletionSchedule  DeletionSchedule?
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique // Hash de la clé pour sécurité
  keyPrefix  String // Prefixe pour affichage (ex: mg_live_abc1...)
  name       String
  scopes     String    @default("full") // Comma-separated: "full" | "read" | "validate" | "export"
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  isActive   Boolean   @default(true)
  deletedAt  DateTime? // NEW: soft-delete timestamp for undo
  restoredAt DateTime? // NEW: audit field
}

model Validation {
  id               String   @id @default(cuid())
  email            String   @db.VarChar(255)
  emailHash        String   @db.VarChar(64) // SHA-256 hash of email for PII privacy
  score            Int
  status           String
  checksJson       Json
  processingTimeMs Int
  algoVersion      Int      @default(1)
  userId           String?
  apiKeyId         String?
  bulkJobId        String?
  createdAt        DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  bulkJob BulkJob? @relation(fields: [bulkJobId], references: [id])

  // Performance indexes
  @@unique([emailHash, userId])
  @@index([email])
  @@index([emailHash])
  @@index([userId, createdAt])
  @@index([bulkJobId])
  @@index([bulkJobId, score])
  @@index([status, createdAt])
}

model BulkJob {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  totalEmails Int
  processed   Int       @default(0)
  status      JobStatus @default(PENDING)
  emailsJson  Json? // Outbox pattern: email data stored in DB, not Redis
  resultUrl   String?
  reportUrl   String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  validations Validation[]

  // Performance indexes
  @@index([userId, createdAt])
  @@index([status])
}

model Webhook {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  url              String
  name             String?
  events           String[] // ['bulk_job_completed', 'daily_report']
  encryptedSecret  String             @db.Text // Secret pour HMAC signing (AES-256-GCM encrypted)
  isActive         Boolean            @default(true)
  privacyMode      Boolean            @default(false) // If true, mask email addresses in webhook payload
  pinnedIps        Json? // ["1.2.3.4", "::1"] — IPs résolues au moment de la création
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?          // NEW: soft-delete timestamp for undo
  restoredAt       DateTime?          // NEW: audit field
  webhookDeliveries WebhookDelivery[]
}

model DeletionSchedule {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RateLimit {
  key     String   @id // Clé de rate limiting (ip:endpoint ou apiKey:endpoint)
  count   Int      @default(0)
  resetAt DateTime // Quand le compteur sera réinitialisé

  @@index([resetAt])
}

model StripeEvent {
  id          String   @id
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // AuditAction enum value
  resource   String // AuditResource enum value
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([action, createdAt])
  @@index([createdAt])
}

model IdempotencyKey {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique @db.VarChar(255)
  response   Json     @db.JsonB
  statusCode Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([key])
  @@index([expiresAt])
}

model ScheduledExport {
  id        String   @id @default(uuid())
  userId    String
  scope     String   // "validations" | "bulk-results"
  format    String   // "csv" | "xlsx" | "pdf"
  frequency String   // "daily" | "weekly" | "monthly"
  filters   Json?
  nextRunAt DateTime
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  @@index([userId])
  @@index([isActive, nextRunAt])
}

model WebhookDelivery {
  id           String   @id @default(uuid()) @db.Uuid
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String   @db.VarChar(100)
  url          String   @db.VarChar(2048)
  status       String   @db.VarChar(20)
  statusCode   Int?
  requestBody  Json     @db.JsonB
  responseBody String?
  durationMs   Int?
  error        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([webhookId, createdAt])
}

// ================================================================
// Feature Flags + Entitlements System
// ================================================================

enum FeatureType {
  BOOLEAN
  LIMIT
  EXPERIMENT
}

enum DowngradeStrategy {
  GRACEFUL
  IMMEDIATE
  FREEZE
}

enum SubscriptionStatusEnum {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum OverrideScope {
  ORG
  USER
}

model PricingPlan {
  id            String   @id @default(cuid())
  key           String   @unique
  name          String
  priceMonthly  Int      @default(0) @map("price_monthly")
  isActive      Boolean  @default(true) @map("is_active")
  stripePriceId String?  @map("stripe_price_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model Feature {
  id          String      @id @default(cuid())
  key         String      @unique
  description String?
  type        FeatureType
  defaultConfig Json?     @default("{}") @map("default_config")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  planFeatures        PlanFeature[]
  entitlementOverrides EntitlementOverride[]

  @@map("features")
}

model PlanFeature {
  id          String            @id @default(cuid())
  planId      String            @map("plan_id")
  featureId   String            @map("feature_id")
  enabled     Boolean           @default(false)
  limitValue  Int?              @map("limit_value")
  configJson  Json?             @default("{}") @map("config_json")
  downgradeStrategy DowngradeStrategy @default(IMMEDIATE) @map("downgrade_strategy")

  plan    PricingPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@map("plan_features")
}

model Organization {
  id               String   @id @default(cuid())
  name             String?
  stripeCustomerId String?  @unique @map("stripe_customer_id")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions   Subscription[]
  usageTracking   UsageTracking[]
  entitlements    EntitlementOverride[] @relation("orgOverrides")
  users           User[]

  @@map("organizations")
}

model Subscription {
  id                 String               @id @default(cuid())
  orgId              String               @map("org_id")
  planKey            String               @map("plan_key")
  status             SubscriptionStatusEnum
  stripeSubId        String?              @unique @map("stripe_sub_id")
  currentPeriodStart DateTime?            @map("current_period_start")
  currentPeriodEnd   DateTime?            @map("current_period_end")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pricingPlan  PricingPlan @relation(fields: [planKey], references: [key], onDelete: Restrict)

  @@unique([orgId, planKey])
  @@index([orgId])
  @@index([stripeSubId])
  @@map("subscriptions")
}

model EntitlementOverride {
  id         String         @id @default(cuid())
  scope      OverrideScope
  scopeId    String         @map("scope_id")
  featureKey String         @map("feature_key")
  enabled    Boolean?
  limitValue Int?           @map("limit_value")
  expiresAt  DateTime?      @map("expires_at")
  reason     String         @default("")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  feature    Feature        @relation(fields: [featureKey], references: [key], onDelete: Cascade)
  org        Organization?  @relation("orgOverrides", fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scope, scopeId, featureKey])
  @@map("entitlement_overrides")
}

model UsageTracking {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  featureKey  String   @map("feature_key")
  usageCount  Int      @default(0) @map("usage_count")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, featureKey, periodStart])
  @@index([orgId, featureKey, periodEnd])
  @@map("usage_tracking")
}
